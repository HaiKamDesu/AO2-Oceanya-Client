<UserControl x:Class="OceanyaClient.AO2ChatPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="RootBorder" Background="#22000000" BorderBrush="#3A4A5E" BorderThickness="1" CornerRadius="4" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRow" Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="HeaderTextBlock"
                       Grid.Row="0"
                       Text="Chat Preview (AO2-style)"
                       Foreground="#FFD8D8D8"
                       FontSize="11"
                       Margin="0,0,0,6"
                       HorizontalAlignment="Center"/>

            <Border x:Name="PreviewFrame"
                    Grid.Row="1"
                    MinWidth="1"
                    MinHeight="1"
                    Background="#1B000000"
                    BorderBrush="#3E4E62"
                    BorderThickness="1"
                    CornerRadius="4">
                <Canvas x:Name="ChatboxCanvas" Width="256" Height="104" ClipToBounds="True">
                    <Image x:Name="ChatboxImage"
                           Canvas.Left="0"
                           Canvas.Top="0"
                           Width="256"
                           Height="104"
                           Stretch="Fill"/>
                    <Border x:Name="FallbackBackground"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            Width="256"
                            Height="104"
                            Background="#CC101010"/>

                    <TextBlock x:Name="ShownameTextBlock"
                               Canvas.Left="1"
                               Canvas.Top="0"
                               Width="46"
                               Height="15"
                               Text="Preview Name"
                               Foreground="White"
                               FontSize="8"
                               TextTrimming="CharacterEllipsis"
                               TextOptions.TextFormattingMode="Display"
                               TextOptions.TextRenderingMode="Aliased"/>

                    <Border x:Name="MessageContainer"
                            Canvas.Left="6"
                            Canvas.Top="12"
                            Width="238"
                            Height="60"
                            Background="#00000000">
                        <RichTextBox x:Name="MessageTextBox"
                                     Foreground="White"
                                     FontSize="12"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     IsReadOnly="True"
                                     IsUndoEnabled="False"
                                     Focusable="False"
                                     HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Top"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     TextOptions.TextFormattingMode="Display"
                                     TextOptions.TextRenderingMode="Aliased"/>
                    </Border>
                </Canvas>
            </Border>
        </Grid>
    </Border>
</UserControl>
