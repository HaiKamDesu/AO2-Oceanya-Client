<local:OceanyaWindowContentControl x:Class="OceanyaClient.CallwordRuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        xmlns:components="clr-namespace:OceanyaClient.Components"
        Height="500"
        Width="680"
        MinHeight="460"
        MinWidth="620">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF171717"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1A1A1A"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFECECEC"/>
            <Setter Property="Background" Value="#FF1F1F1F"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF36506A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF3D5E7F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,28,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ToggleButton x:Name="DropdownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="SelectionBoxPresenter"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     Foreground="{TemplateBinding Foreground}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Hidden"
                                     Focusable="True"/>
                            <Path HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False"
                                  Fill="#FFDCDCDC"
                                  Data="M 0 0 L 8 0 L 4 5 Z"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#FF1F1F1F"
                                        BorderBrush="#FF4A4A4A"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer CanContentScroll="True" MaxHeight="320">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SelectionBoxPresenter" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FF6E93BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Background" Value="#FF1A1A1A"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE2E2E2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="HelpGlyph" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9FC3DF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Text" Value="(?)"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Trigger Type" Style="{StaticResource LabelText}"/>
            <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="AO2 Callword syncs with config.ini. Other trigger types are Oceanya-only and can use custom SFX."/>
        </StackPanel>
        <local:AutoCompleteDropdownField Grid.Row="1"
                                         x:Name="TriggerTypeDropdown"
                                         IsTextReadOnly="True"
                                         PreserveItemOrder="True"
                                         TextValueChanged="TriggerTypeDropdown_TextValueChanged"
                                         Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" x:Name="TextValueLabelRow" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock x:Name="TextValueLabel" Text="Callword" Style="{StaticResource LabelText}"/>
            <TextBlock x:Name="TextValueHelpGlyph" Style="{StaticResource HelpGlyph}" ToolTip="Manual text used by the selected trigger."/>
        </StackPanel>
        <TextBox Grid.Row="3" x:Name="TextValueTextBox" Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"/>

        <CheckBox Grid.Row="4"
                  x:Name="WholeWordCheckBox"
                  Content="Whole word"
                  Foreground="White"
                  Margin="0,0,0,12"
                  Visibility="Collapsed"
                  ToolTip="Only match when the text is a complete word or phrase, so Kam matches 'Kam, hello' but not 'Kamui'."/>

        <StackPanel Grid.Row="5" x:Name="CharacterLabelRow" Orientation="Horizontal" Margin="0,0,0,6" Visibility="Collapsed">
            <TextBlock Text="Character" Style="{StaticResource LabelText}"/>
            <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Local character folder to match. Use the lookup button to open the database viewer."/>
        </StackPanel>
        <Grid Grid.Row="6" x:Name="CharacterRow" Visibility="Collapsed" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <components:ImageComboBox x:Name="CharacterComboBox"
                                      Height="30"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,8,0"
                                      OnConfirm="CharacterComboBox_OnConfirm"/>
            <Button x:Name="CharacterLookupButton" Grid.Column="1" Content="..." Width="40" Style="{StaticResource ModernButton}" Click="CharacterLookupButton_Click" ToolTip="Open character lookup."/>
        </Grid>

        <StackPanel Grid.Row="7" x:Name="EmoteLabelRow" Orientation="Horizontal" Margin="0,0,0,6" Visibility="Collapsed">
            <TextBlock Text="Emote" Style="{StaticResource LabelText}"/>
            <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Character emote ID/display name to match after the selected character is chosen."/>
        </StackPanel>
        <components:ImageComboBox Grid.Row="8"
                                  x:Name="EmoteComboBox"
                                  Height="30"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,12"
                                  Visibility="Collapsed"
                                  OnConfirm="EmoteComboBox_OnConfirm"/>

        <Grid Grid.Row="9" x:Name="SoundSection" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Sound" Style="{StaticResource LabelText}"/>
                <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Custom SFX for this trigger. Default uses AO2's word_call/modcall notification sound."/>
            </StackPanel>
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SoundPathTextBox" Style="{StaticResource DarkTextBox}" IsReadOnly="True" ToolTip="Selected custom SFX file. Use Browse; do not type paths."/>
                <local:PlayStopProgressButton Grid.Column="1"
                                              x:Name="PreviewButton"
                                              Width="36"
                                              Height="36"
                                              Margin="8,0,8,0"
                                              ProgressEnabled="True"
                                              AutoProgress="True"
                                              ToolTipText="Preview selected or default callword SFX."
                                              PlayRequested="PreviewButton_PlayRequested"
                                              StopRequested="PreviewButton_StopRequested"
                                              PlaybackCompleted="PreviewButton_PlaybackCompleted"/>
                <Button Grid.Column="2" Content="..." Width="40" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="BrowseButton_Click" ToolTip="Pick an AO2-compatible audio file."/>
                <Button Grid.Column="3" Content="Default" Style="{StaticResource ModernButton}" Click="UseDefaultButton_Click" ToolTip="Clear custom sound and use AO2 default notification SFX."/>
            </Grid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Volume" Style="{StaticResource LabelText}"/>
                <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Playback volume for this callword sound. 100% keeps normal volume, 50% halves it, 0% mutes it."/>
                <TextBox x:Name="VolumeValueTextBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="76"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         TextChanged="VolumeValueTextBox_TextChanged"
                         LostFocus="VolumeValueTextBox_LostFocus"
                         ToolTip="Exact volume percent. The slider is limited to 0-200, but this field accepts any positive number."/>
            </StackPanel>
            <Slider Grid.Row="3" x:Name="VolumeSlider" Minimum="0" Maximum="200" ValueChanged="VolumeSlider_ValueChanged"/>
        </Grid>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="96" Content="OK" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button Width="96" Content="Cancel" Style="{StaticResource ModernButton}" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</local:OceanyaWindowContentControl>
