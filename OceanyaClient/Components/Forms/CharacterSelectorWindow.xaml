<local:OceanyaWindowContentControl x:Class="OceanyaClient.CharacterSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        Height="640"
        Width="760"
        MinHeight="380"
        MinWidth="480">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF171717"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1A1A1A"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <!-- Card border default state -->
        <Style x:Key="CharCardBorder" TargetType="Border">
            <Setter Property="Width" Value="82"/>
            <Setter Property="Height" Value="94"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SectionExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="#FFECECEC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#FFECECEC" FontWeight="SemiBold" FontSize="13" Margin="4,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Client name row (hidden when not adding a new client) -->
        <Grid Grid.Row="0" x:Name="ClientNameRow" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Client Name:" Foreground="#FFB0B0B0" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
            <TextBox Grid.Column="1"
                     x:Name="ClientNameBox"
                     Style="{StaticResource DarkTextBox}"
                     AutomationProperties.AutomationId="CharacterSelector.ClientName"
                     ToolTip="Name for this client."/>
        </Grid>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Search:" Foreground="#FFB0B0B0" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
            <TextBox Grid.Column="1"
                     x:Name="SearchBox"
                     Style="{StaticResource DarkTextBox}"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Filter characters by name or category."/>
        </Grid>

        <!-- Character sections -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SectionsPanel"/>
        </ScrollViewer>

        <!-- Bottom bar: icon size slider left, Cancel right -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Icon size" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="IconSizeSlider"
                        Width="130"
                        Minimum="0.5"
                        Maximum="3.0"
                        Value="1.0"
                        SmallChange="0.1"
                        LargeChange="0.5"
                        TickFrequency="0.5"
                        VerticalAlignment="Center"
                        ValueChanged="IconSizeSlider_ValueChanged"/>
                <TextBlock x:Name="IconSizeLabel"
                           Text="1.0×"
                           Foreground="#FFB0B0B0"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Width="38"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Width="96" Content="Cancel" Style="{StaticResource ModernButton}"
                        AutomationProperties.AutomationId="CharacterSelector.Cancel"
                        Click="CancelButton_Click" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</local:OceanyaWindowContentControl>
