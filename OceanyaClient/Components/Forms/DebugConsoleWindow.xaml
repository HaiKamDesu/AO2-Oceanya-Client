<local:OceanyaWindowContentControl x:Class="OceanyaClient.DebugConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="600"
        Width="900"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <local:OceanyaWindowContentControl.Resources>
        <!-- Console RichTextBox style -->
        <Style x:Key="ConsoleRichTextBoxStyle" TargetType="{x:Type RichTextBox}">
            <Setter Property="Background" Value="#33262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsDocumentEnabled" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Filter toggle button style -->
        <Style x:Key="FilterToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#777777"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4DA6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category checkbox style -->
        <Style x:Key="CategoryCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Utility action button style (e.g. Clear) -->
        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#777777"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE81123" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFC41E3A" TargetName="ButtonBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Animations -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </local:OceanyaWindowContentControl.Resources>

    <local:OceanyaWindowContentControl.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </local:OceanyaWindowContentControl.Triggers>

    <local:OceanyaWindowContentControl.Opacity>1</local:OceanyaWindowContentControl.Opacity>

    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Category filter bar -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ToggleButton x:Name="FilterDropdownToggle"
                          Grid.Column="0"
                          Style="{StaticResource FilterToggleButtonStyle}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Log Filters" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FilterArrow" Text=" ▼" VerticalAlignment="Center" Foreground="#888888"/>
                </StackPanel>
            </ToggleButton>

            <Popup Grid.Column="0"
                   x:Name="FilterPopup"
                   PlacementTarget="{Binding ElementName=FilterDropdownToggle}"
                   Placement="Bottom"
                   IsOpen="{Binding IsChecked, ElementName=FilterDropdownToggle, Mode=TwoWay}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <Border Background="#1E1E1E"
                        BorderBrush="#555555"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="12,8"
                        Effect="{x:Null}">
                    <StackPanel MinWidth="180">
                        <TextBlock Text="CATEGORIES" Foreground="#666666" FontFamily="Consolas" FontSize="10"
                                   Margin="0,0,0,6"/>
                        <CheckBox x:Name="FilterSystem"
                                  Content="System"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterNetwork"
                                  Content="Network (Packets)"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterIC"
                                  Content="IC Messages"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterOOC"
                                  Content="OOC Messages"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterViewport"
                                  Content="Viewport"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterMusicList"
                                  Content="Music List"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterAreaVisualizer"
                                  Content="Area visualizer"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                        <CheckBox x:Name="FilterSFX"
                                  Content="SFX"
                                  Style="{StaticResource CategoryCheckBoxStyle}"
                                  Checked="CategoryFilter_Changed"
                                  Unchecked="CategoryFilter_Changed"/>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Active filter summary label -->
            <TextBlock x:Name="FilterSummaryLabel"
                       Grid.Column="1"
                       Foreground="#666666"
                       FontFamily="Consolas"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       TextTrimming="CharacterEllipsis"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnExportLog"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnExportLog_Click"
                        ToolTip="Export currently visible console output to a text file">
                    <TextBlock Text="Export" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="BtnClearLog"
                        Margin="6,0,0,0"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="BtnClearLog_Click"
                        ToolTip="Clear console output">
                    <TextBlock Text="Clear" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Console output -->
        <RichTextBox x:Name="ConsoleTextBox"
                     Grid.Row="1"
                     Style="{StaticResource ConsoleRichTextBoxStyle}"
                     Background="#26262626">
            <RichTextBox.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3399FF" Opacity="0.4"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
            </RichTextBox.Resources>
        </RichTextBox>
    </Grid>
</local:OceanyaWindowContentControl>
