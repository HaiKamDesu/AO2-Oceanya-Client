<local:OceanyaWindowContentControl x:Class="OceanyaClient.ExtraAudioRuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        xmlns:components="clr-namespace:OceanyaClient.Components"
        Height="430"
        Width="660"
        MinHeight="390"
        MinWidth="600">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF171717"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF1A1A1A"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF333333"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFECECEC"/>
            <Setter Property="Background" Value="#FF1F1F1F"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,28,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"/>
                            <ToggleButton Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                            <Path HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False"
                                  Fill="#FFDCDCDC"
                                  Data="M 0 0 L 8 0 L 4 5 Z"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#FF1F1F1F"
                                        BorderBrush="#FF4A4A4A"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer CanContentScroll="True" MaxHeight="320">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FF6E93BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE2E2E2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="HelpGlyph" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9FC3DF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Text" Value="(?)"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Extra audio rules only use known values from your local AO2 install."
                   Style="{StaticResource SubText}" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Rule type" Style="{StaticResource LabelText}"/>
            <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="What kind of audio this rule changes. Blip rules change message talking sounds."/>
        </StackPanel>
        <local:AutoCompleteDropdownField Grid.Row="2"
                                         x:Name="KindDropdown"
                                         IsTextReadOnly="True"
                                         PreserveItemOrder="True"
                                         Margin="0,0,0,12"
                                         TextValueChanged="KindDropdown_TextValueChanged"/>

        <StackPanel Grid.Row="3" x:Name="TargetLabelRow" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Applies to" Style="{StaticResource LabelText}"/>
            <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Choose what the rule matches. SFX rules apply to one SFX token. Music rules directly choose one music token."/>
        </StackPanel>
        <local:AutoCompleteDropdownField Grid.Row="4"
                                         x:Name="TargetDropdown"
                                         IsTextReadOnly="True"
                                         PreserveItemOrder="True"
                                         Margin="0,0,0,12"
                                         TextValueChanged="TargetDropdown_TextValueChanged"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock x:Name="MatchLabel" Text="Value" Style="{StaticResource LabelText}"/>
            <TextBlock x:Name="MatchHelpGlyph" Style="{StaticResource HelpGlyph}" ToolTip="Pick the exact local character, showname, or blip token for this rule."/>
        </StackPanel>
        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <components:ImageComboBox x:Name="CharacterComboBox"
                                      Height="30"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,8,12"
                                      OnConfirm="CharacterComboBox_OnConfirm"/>
            <TextBox x:Name="ShownameTextBox"
                     Style="{StaticResource DarkTextBox}"
                     Grid.ColumnSpan="3"
                     Margin="0,0,8,12"
                     Visibility="Collapsed"/>
            <local:AutoCompleteDropdownField x:Name="BlipDropdown"
                                             Grid.ColumnSpan="2"
                                             Margin="0,0,8,12"
                                             Visibility="Collapsed"
                                             TextValueChanged="BlipDropdown_TextValueChanged"/>
            <local:AutoCompleteDropdownField x:Name="SfxDropdown"
                                             Grid.ColumnSpan="2"
                                             Margin="0,0,8,12"
                                             Visibility="Collapsed"
                                             TextValueChanged="AudioTokenDropdown_TextValueChanged"/>
            <local:AutoCompleteDropdownField x:Name="MusicDropdown"
                                             Grid.ColumnSpan="2"
                                             Margin="0,0,8,12"
                                             Visibility="Collapsed"
                                             TextValueChanged="AudioTokenDropdown_TextValueChanged"/>
            <Button x:Name="CharacterLookupButton" Grid.Column="1" Content="..." Width="40" Style="{StaticResource ModernButton}" Margin="0,0,0,12" Click="CharacterLookupButton_Click" ToolTip="Open character lookup."/>
            <local:PlayStopProgressButton x:Name="BlipPreviewButton"
                                          Grid.Column="2"
                                          Width="36"
                                          Height="36"
                                          Margin="0,0,0,12"
                                          ProgressEnabled="True"
                                          AutoProgress="True"
                                          ToolTipText="Preview resolved blip."
                                          Visibility="Collapsed"
                                          PlayRequested="BlipPreviewButton_PlayRequested"
                                          StopRequested="BlipPreviewButton_StopRequested"
                                          PlaybackCompleted="BlipPreviewButton_PlaybackCompleted"/>

            <CheckBox Grid.Row="1"
                      Grid.ColumnSpan="2"
                      x:Name="ShownameCaseSensitiveCheckBox"
                      Content="Case sensitive"
                      Foreground="White"
                      Margin="0,0,0,12"
                      Visibility="Collapsed"
                      ToolTip="When enabled, showname matching must use the exact same uppercase/lowercase letters you typed."/>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Volume" Style="{StaticResource LabelText}"/>
                <TextBlock Style="{StaticResource HelpGlyph}" ToolTip="Final volume for matching audio. 100% keeps normal volume, 50% halves it, 0% mutes it."/>
                <TextBox x:Name="VolumeValueTextBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="76"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         TextChanged="VolumeValueTextBox_TextChanged"
                         LostFocus="VolumeValueTextBox_LostFocus"
                         ToolTip="Exact volume percent. The slider is limited to 0-200, but this field accepts any positive number."/>
            </StackPanel>
            <Slider Grid.Row="3" Grid.ColumnSpan="2" x:Name="VolumeSlider" Minimum="0" Maximum="200" ValueChanged="VolumeSlider_ValueChanged"/>
        </Grid>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="96" Content="OK" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button Width="96" Content="Cancel" Style="{StaticResource ModernButton}" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</local:OceanyaWindowContentControl>
