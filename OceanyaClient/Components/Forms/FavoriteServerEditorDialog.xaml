<local:OceanyaWindowContentControl x:Class="OceanyaClient.FavoriteServerEditorDialog"
                                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                   xmlns:local="clr-namespace:OceanyaClient">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FFD9D9D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#FF9FA8B0"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="DescriptionTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Height" Value="180"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FF23272D"/>
            <Setter Property="Foreground" Value="#FFF3F3F3"/>
            <Setter Property="BorderBrush" Value="#FF4A5562"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF2A3038"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF171B20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF181C21"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF313844"/>
                                <Setter Property="Foreground" Value="#FF7F8791"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="18,14,18,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="14,12"
                Background="#AA151A20"
                BorderBrush="#FF334252"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Favorite Server Profile"
                           Foreground="#FFF5F7FA"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Save a reusable direct-connect endpoint for the multiclient launch flow. TCP, WebSocket, and secure WebSocket endpoints are supported."
                           Margin="0,6,0,0"
                           Foreground="#FFAFBCC8"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="SERVER NAME" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="ServerNameTextBox"
                     Style="{StaticResource ModernTextBox}"
                     Background="#FF262626"/>
            <TextBlock Text="Use a short label that is easy to recognize from the launch screen."
                       Style="{StaticResource HelperTextStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="SERVER ENDPOINT" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="ServerEndpointTextBox"
                     Style="{StaticResource ModernTextBox}"
                     Background="#FF262626"/>
            <TextBlock Text="Examples: tcp://127.0.0.1:27016, ws://127.0.0.1:27016, or wss://example.com:443"
                       Style="{StaticResource HelperTextStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="ServerDescriptionTextBox"
                     Style="{StaticResource DescriptionTextBox}"
                     Background="#FF262626"/>
            <TextBlock Text="Optional notes for the server list. URLs remain clickable from the selection popup."
                       Style="{StaticResource HelperTextStyle}"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#FF8C97A1"
                       FontSize="11.5"
                       Text="Favorites are stored locally next to your config.ini."/>

            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Content="CANCEL"
                    Style="{StaticResource ModernButton}"
                    Click="CancelButton_Click"/>
            <Button x:Name="ActionButton"
                    Grid.Column="2"
                    Content="SAVE"
                    Style="{StaticResource ModernButton}"
                    Background="#FF254157"
                    BorderBrush="#FF6A8EAF"
                    Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</local:OceanyaWindowContentControl>
