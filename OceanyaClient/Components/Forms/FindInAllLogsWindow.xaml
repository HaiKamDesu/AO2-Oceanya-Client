<local:OceanyaWindowContentControl x:Class="OceanyaClient.Components.Forms.FindInAllLogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        Width="1060" Height="680"
        MinWidth="850"
        MinHeight="520"
        PreviewKeyDown="FindWindow_PreviewKeyDown"
        ShowInTaskbar="False">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="FindDarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="FindDarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="74"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FindIconButton" TargetType="Button" BasedOn="{StaticResource FindDarkButton}">
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="FindDarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="PanelLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB6C3CE"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="#18262626"/>
            <Setter Property="BorderBrush" Value="#33444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionBorder}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Search all log files" Foreground="White" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="TxtStatus"
                               Style="{StaticResource SubText}"
                               TextAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtSearch"
                             Grid.Column="0"
                             Style="{StaticResource FindDarkTextBox}"
                             VerticalContentAlignment="Center"
                             ToolTip="Search every .log file under the AO2 logs folder"
                             KeyDown="TxtSearch_KeyDown"/>
                    <Button x:Name="BtnFind"
                            Grid.Column="1"
                            Content="Find"
                            Style="{StaticResource FindDarkButton}"
                            Margin="8,0,0,0"
                            Click="BtnFind_Click"/>
                    <Button x:Name="BtnCancel"
                            Grid.Column="2"
                            Content="Cancel"
                            Style="{StaticResource FindDarkButton}"
                            Margin="4,0,0,0"
                            IsEnabled="False"
                            Click="BtnCancel_Click"/>
                    <TextBlock Grid.Column="3"
                               Text="Match"
                               Style="{StaticResource SubText}"
                               VerticalAlignment="Center"
                               Margin="14,0,4,0"/>
                    <Button x:Name="BtnPrev"
                            Grid.Column="4"
                            Content="↑"
                            Style="{StaticResource FindIconButton}"
                            IsEnabled="False"
                            Click="BtnPrev_Click"
                            ToolTip="Previous match (Shift+Enter, Shift+F3, Ctrl+Shift+G)"/>
                    <Button x:Name="BtnNext"
                            Grid.Column="5"
                            Content="↓"
                            Style="{StaticResource FindIconButton}"
                            Margin="4,0,0,0"
                            IsEnabled="False"
                            Click="BtnNext_Click"
                            ToolTip="Next match (Enter, F3, Ctrl+G)"/>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkSearchIC"
                                  Content="Search IC"
                                  Style="{StaticResource FindDarkCheckBox}"
                                  Margin="0,0,12,0"
                                  IsChecked="True"/>
                        <CheckBox x:Name="ChkSearchOOC"
                                  Content="Search OOC"
                                  Style="{StaticResource FindDarkCheckBox}"
                                  Margin="0,0,18,0"
                                  IsChecked="True"/>
                        <CheckBox x:Name="ChkMatchCase"
                                  Content="Case"
                                  Style="{StaticResource FindDarkCheckBox}"
                                  Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkWholeWord"
                                  Content="Word"
                                  Style="{StaticResource FindDarkCheckBox}"
                                  Margin="0,0,12,0"/>
                        <CheckBox x:Name="ChkRegex"
                                  Content="Regex"
                                  Style="{StaticResource FindDarkCheckBox}"/>
                    </WrapPanel>
                    <TextBlock x:Name="TxtResultCount"
                               Grid.Column="1"
                               Style="{StaticResource SubText}"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <Border Grid.Row="3"
                        Background="#20262626"
                        BorderBrush="#22444444"
                        BorderThickness="1"
                        Padding="8,5"
                        Margin="0,8,0,0">
                    <TextBlock x:Name="TxtSearchSummary"
                               Style="{StaticResource SubText}"
                               Text="Logs: 0 total | Lines: 0 | Search: not run"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Text="Matching files" Style="{StaticResource PanelLabel}" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="TxtFileCount" Style="{StaticResource SubText}" DockPanel.Dock="Right" TextAlignment="Right"/>
                </DockPanel>
                <ListBox x:Name="ResultsList"
                         Grid.Row="1"
                         Background="#33262626"
                         Foreground="White"
                         BorderBrush="#44444444"
                         BorderThickness="1"
                         ItemsSource="{Binding Results}"
                         SelectionChanged="ResultsList_SelectionChanged"
                         PreviewMouseRightButtonDown="ResultsList_PreviewMouseRightButtonDown"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open file location" Click="OpenFileLocationMenuItem_Click"/>
                            <MenuItem Header="Open file" Click="OpenFileMenuItem_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" BorderBrush="#22444444" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MatchCountText}" Foreground="#FFFFD840" FontWeight="SemiBold" Margin="8,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding DetailText}" Foreground="#FFB6C3CE" FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock x:Name="TxtSelectedFile" Text="No file selected" Style="{StaticResource PanelLabel}" DockPanel.Dock="Left" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TxtSelectedFileDetail" Style="{StaticResource SubText}" DockPanel.Dock="Right" TextAlignment="Right"/>
                </DockPanel>
                <RichTextBox x:Name="FilePreview"
                             Grid.Row="1"
                             Background="#33262626"
                             Foreground="White"
                             BorderBrush="#44444444"
                             BorderThickness="1"
                             Padding="8,5"
                             FontFamily="Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
            </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Right-click a matching file to open it or reveal it in File Explorer."
                   Style="{StaticResource SubText}"
                   Margin="0,8,0,0"/>
    </Grid>
</local:OceanyaWindowContentControl>
