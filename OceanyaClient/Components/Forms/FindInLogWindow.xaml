<local:OceanyaWindowContentControl x:Class="OceanyaClient.Components.Forms.FindInLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        Width="465" Height="58"
        MinWidth="465"
        MinHeight="58"
        PreviewKeyDown="FindWindow_PreviewKeyDown"
        ShowInTaskbar="False">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="FindDarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="FindDarkButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FindDarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"
                     Grid.Column="0"
                     VerticalContentAlignment="Center"
                     Style="{StaticResource FindDarkTextBox}"
                     ToolTip="Type to search selected logs"
                     KeyDown="TxtSearch_KeyDown"/>

            <Button x:Name="BtnPrev"
                    Grid.Column="1"
                    Content="↑"
                    Style="{StaticResource FindDarkButton}"
                    Margin="4,0,0,0"
                    IsEnabled="False"
                    Click="BtnPrev_Click"
                    ToolTip="Previous match (Shift+Enter, Shift+F3, Ctrl+Shift+G)"/>

            <Button x:Name="BtnNext"
                    Grid.Column="2"
                    Content="↓"
                    Style="{StaticResource FindDarkButton}"
                    Margin="2,0,0,0"
                    IsEnabled="False"
                    Click="BtnNext_Click"
                    ToolTip="Next match (Enter, F3, Ctrl+G)"/>

            <TextBlock x:Name="TxtResultCount"
                       Grid.Column="3"
                       Text="No results"
                       VerticalAlignment="Center"
                       Foreground="#FFB6C3CE"
                       Margin="8,0,0,0"
                       FontSize="12"
                       MinWidth="82"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <CheckBox x:Name="ChkSearchIC"
                      Content="Search IC"
                      Style="{StaticResource FindDarkCheckBox}"
                      Margin="0,0,12,0"
                      ToolTip="Include IC log matches"
                      Checked="SearchOptions_Changed"
                      Unchecked="SearchOptions_Changed"/>
            <CheckBox x:Name="ChkSearchOOC"
                      Content="Search OOC"
                      Style="{StaticResource FindDarkCheckBox}"
                      Margin="0,0,18,0"
                      ToolTip="Include OOC log matches"
                      Checked="SearchOptions_Changed"
                      Unchecked="SearchOptions_Changed"/>
            <CheckBox x:Name="ChkMatchCase"
                      Content="Case"
                      Style="{StaticResource FindDarkCheckBox}"
                      Margin="0,0,12,0"
                      Checked="SearchOptions_Changed"
                      Unchecked="SearchOptions_Changed"/>
            <CheckBox x:Name="ChkWholeWord"
                      Content="Word"
                      Style="{StaticResource FindDarkCheckBox}"
                      Margin="0,0,12,0"
                      Checked="SearchOptions_Changed"
                      Unchecked="SearchOptions_Changed"/>
            <CheckBox x:Name="ChkRegex"
                      Content="Regex"
                      Style="{StaticResource FindDarkCheckBox}"
                      Checked="SearchOptions_Changed"
                      Unchecked="SearchOptions_Changed"/>
        </StackPanel>
    </Grid>
</local:OceanyaWindowContentControl>
