<local:OceanyaWindowContentControl x:Class="OceanyaClient.GoogleDriveSyncWindow"
                                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                   xmlns:local="clr-namespace:OceanyaClient"
                                   Width="940"
                                   Height="760"
                                   MinWidth="780"
                                   MinHeight="620"
                                   Background="Transparent">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D3D" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF171717" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF1A1A1A" TargetName="ButtonBorder"/>
                                <Setter Property="BorderBrush" Value="#FF333333" TargetName="ButtonBorder"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BodyHintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFBEBEBE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#C8181818"/>
            <Setter Property="BorderBrush" Value="#FF363636"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="StatusLogStyle" TargetType="RichTextBox">
            <Setter Property="Background" Value="#FF171717"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="#FFE7E7E7"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsDocumentEnabled" Value="False"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style x:Key="SelectableInfoTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style x:Key="HelpBadgeStyle" TargetType="Button">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFBDBDBD"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="120"/>
            <Setter Property="ToolTipService.ShowDuration" Value="600000"/>
            <Setter Property="ToolTipService.Placement" Value="Right"/>
            <Setter Property="ToolTipService.HorizontalOffset" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF1C1C1C"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="BorderBrush" Value="#FF4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="460"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   MaxWidth="430"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14">
            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OVERVIEW"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This window links a shared Google Drive folder to a normal local AO asset folder so Oceanya can pull, publish, and refresh assets without leaving the client."/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyHintText}"
                               Text="Use this popup to configure one saved Google Drive connection. Typical flow: name the connection, sign in, create or paste a Drive folder, choose a local sync folder, ensure the mount path exists, then publish or pull changes as needed."/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                        <TextBlock Text="CONNECTION NAME"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="A local label for this saved connection inside The Oceanyan File Hivemind manager. This does not need to match the Drive folder name."/>
                    </StackPanel>
                    <TextBox x:Name="ConnectionNameTextBox"
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GOOGLE CLOUD"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This connection carries its own Google Cloud Desktop app credentials. The host sets these up once, exports the connection file, and everyone else imports it."/>
                    </StackPanel>

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource BodyHintText}"
                               Text="Host setup only: create a Google Cloud Desktop app OAuth client, paste the client ID and client secret here, then export the connection file for friends. Every participant still signs into their own Google account in the normal browser window."/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                        <TextBlock Text="CLIENT ID"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Google Cloud setup: create or select a project, enable Google Drive API, open Google Auth Platform, set the audience to External if needed, add test users while the app is in testing, then create a Desktop app OAuth client and paste its client ID here."/>
                    </StackPanel>
                    <TextBox x:Name="GoogleCloudClientIdTextBox"
                             Style="{StaticResource ModernTextBox}"
                             TextChanged="GoogleCloudCredentialFields_Changed"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                        <TextBlock Text="CLIENT SECRET"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Paste the Desktop app client secret from Google Cloud here. Oceanya stores it locally for this connection and hides it after save. Exported connection files include an obfuscated copy of the Google Cloud app credentials, but never include any user's Google login tokens."/>
                    </StackPanel>
                    <PasswordBox x:Name="GoogleCloudClientSecretPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 PasswordChanged="GoogleCloudClientSecretPasswordBox_PasswordChanged"
                                 GotKeyboardFocus="GoogleCloudClientSecretPasswordBox_GotKeyboardFocus"
                                 LostKeyboardFocus="GoogleCloudClientSecretPasswordBox_LostKeyboardFocus"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                        <TextBlock Text="CLOUD STATUS"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Shows whether this connection currently has usable Google Cloud credentials. Imported connections keep the secret hidden in local storage, so this status is the safest way to confirm they are ready."/>
                    </StackPanel>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="VerifyCloudCredentialsButton"
                                Grid.Column="0"
                                Width="110"
                                Content="Verify"
                                Style="{StaticResource ModernButton}"
                                Click="VerifyCloudCredentialsButton_Click"
                                ToolTip="Check whether this Google Cloud Desktop app client ID and client secret look usable. If the account is already signed in, Oceanya can fully verify them by contacting Google with the saved tokens; otherwise it performs a client-auth probe."/>

                        <Border Grid.Column="2"
                                Padding="10"
                                Background="#991F2327"
                                BorderBrush="#FF3D4B57"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox x:Name="CloudCredentialStatusTextBlock"
                                     Style="{StaticResource SelectableInfoTextBox}"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="GOOGLE ACCOUNT"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This section controls the actual user login. Every participant signs into their own Google account here after the connection's Google Cloud Desktop app credentials are configured."/>
                    </StackPanel>

                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource BodyHintText}"
                               Text="Once the Google Cloud section is configured and verified, users only need to click Sign In and complete the normal Google browser login."/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="SignInButton"
                                Width="110"
                                Content="Sign In"
                                Style="{StaticResource ModernButton}"
                                Click="SignInButton_Click"
                                ToolTip="Open Google's normal browser sign-in page with this connection's Google Cloud client and store the returned user tokens securely for this Windows user."/>
                        <Button x:Name="SignOutButton"
                                Width="110"
                                Margin="8,0,0,0"
                                Content="Sign Out"
                                Style="{StaticResource ModernButton}"
                                Click="SignOutButton_Click"
                                ToolTip="Delete the locally stored encrypted Google user tokens for this sync connection. This does not delete the Google Cloud client secret."/>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,5">
                        <TextBlock Text="ACCOUNT STATUS"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Shows which Google account is currently connected and the timestamp of the last successful sync if one exists."/>
                    </StackPanel>
                    <Border Padding="10"
                            Background="#9922262B"
                            BorderBrush="#FF3D4B57"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBox x:Name="AccountStatusTextBlock"
                                 Text="Not signed in."
                                 Style="{StaticResource SelectableInfoTextBox}"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REMOTE DRIVE FOLDER"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This is the shared Google Drive folder that acts as the remote campaign asset store."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                        <TextBlock Text="DRIVE FOLDER ID OR SHARE LINK"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Paste either the raw Google Drive folder ID or the normal share link. Oceanya will extract the folder ID automatically."/>
                    </StackPanel>
                    <TextBox x:Name="RemoteFolderTextBox"
                             Style="{StaticResource ModernTextBox}"
                             TextChanged="RemoteFolderTextBox_TextChanged"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="VerifyRemoteFolderButton"
                                Grid.Column="0"
                                Width="110"
                                Content="Verify"
                                Style="{StaticResource ModernButton}"
                                Click="VerifyRemoteFolderButton_Click"
                                ToolTip="Resolve the current share link or folder ID, confirm the signed-in account can access it, and fetch the real Google Drive folder name."/>

                        <Border Grid.Column="2"
                                Padding="10"
                                Background="#9922262B"
                                BorderBrush="#FF3D4B57"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBox x:Name="RemoteFolderStatusTextBlock"
                                     Foreground="#FFBEBEBE"
                                     Style="{StaticResource SelectableInfoTextBox}"
                                     Text="Paste a Google Drive folder share link or folder ID, then click Verify."/>
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LOCAL MIRROR FOLDER"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This is the normal local AO-readable folder that Oceanya keeps in sync with the remote Drive folder."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                        <TextBlock Text="LOCAL SYNC FOLDER"
                                   Style="{StaticResource LabelText}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Oceanya downloads Drive assets into this folder and reads local changes from here when publishing back to Drive."/>
                    </StackPanel>
                    <TextBox x:Name="LocalFolderTextBox"
                             Style="{StaticResource ModernTextBox}"/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="CreateManagedFolderButton"
                                Width="190"
                                Content="Generate Folder Automatically"
                                Style="{StaticResource ModernButton}"
                                Click="CreateManagedFolderButton_Click"
                                ToolTip="Generate and select an Oceanya-managed local mirror folder using the connection name, Drive folder name, and Drive folder ID."/>
                        <Button x:Name="MoveLocalFolderButton"
                                Width="120"
                                Margin="8,0,0,0"
                                Content="Move Folder..."
                                Style="{StaticResource ModernButton}"
                                Click="MoveLocalFolderButton_Click"
                                ToolTip="Move the current local mirror folder to a different parent directory and update the saved path for this connection."/>
                        <Button x:Name="BrowseLocalFolderButton"
                                Width="120"
                                Margin="8,0,0,0"
                                Content="Browse..."
                                Style="{StaticResource ModernButton}"
                                Click="BrowseLocalFolderButton_Click"
                                ToolTip="Choose an existing local folder to use as the sync mirror."/>
                        <Button x:Name="OpenLocalFolderButton"
                                Width="120"
                                Margin="8,0,0,0"
                                Content="Open Folder"
                                Style="{StaticResource ModernButton}"
                                Click="OpenLocalFolderButton_Click"
                                ToolTip="Open the current local sync folder in the system file explorer."/>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox x:Name="AutoAddMountPathCheckBox"
                                  Style="{StaticResource ModernCheckBox}"
                                  Content="Automatically add the local sync folder to AO mount paths"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="If enabled, Oceanya will try to add the local mirror folder to mount_paths so AO can resolve these assets immediately."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="UseExistingMountPathCheckBox"
                                  Style="{StaticResource ModernCheckBox}"
                                  Content="I am intentionally reusing an existing AO asset mount folder"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Enable this only if you deliberately want Google Drive sync to write into a folder you already use as an AO asset mount."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox x:Name="MirrorDeletesCheckBox"
                                  Style="{StaticResource ModernCheckBox}"
                                  Content="Mirror deletions between the local folder and Google Drive"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="If enabled, files missing on one side can be deleted on the other during sync. Leave this off if you want a safer first test."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SYNC ACTIONS"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="Use these actions to update mount paths, transfer files between Drive and the local mirror, and make AO/Oceanya re-read the assets."/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource BodyHintText}"
                               Text="Recommended order: ensure mount path once, publish or pull changes, then refresh AO assets so the current session sees the latest files immediately."/>

                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="EnsureMountPathButton"
                                Width="140"
                                Content="Ensure Mount Path"
                                Style="{StaticResource ModernButton}"
                                Click="EnsureMountPathButton_Click"
                                ToolTip="Make sure the current local sync folder exists in the selected AO config.ini mount_paths entry."/>
                        <Button x:Name="PullFromDriveButton"
                                Width="140"
                                Margin="8,0,0,0"
                                Content="Sync From Drive"
                                Style="{StaticResource ModernButton}"
                                Click="PullFromDriveButton_Click"
                                ToolTip="Download the current Google Drive contents into the local sync folder using the active sync settings."/>
                        <Button x:Name="PushToDriveButton"
                                Width="150"
                                Margin="8,0,0,0"
                                Content="Publish Local Folder"
                                Style="{StaticResource ModernButton}"
                                Click="PushToDriveButton_Click"
                                ToolTip="Upload the current local sync folder contents to Google Drive so other clients can pull the changes."/>
                        <Button x:Name="RefreshAssetsButton"
                                Width="140"
                                Margin="8,0,0,0"
                                Content="Refresh AO Assets"
                                Style="{StaticResource ModernButton}"
                                Click="RefreshAssetsButton_Click"
                                ToolTip="Re-read config.ini and rebuild the relevant character/background asset indexes immediately."/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STATUS LOG"
                                   Style="{StaticResource SectionTitleText}"/>
                        <Button Content="(?)"
                                Style="{StaticResource HelpBadgeStyle}"
                                ToolTip="This log shows sign-in progress, folder operations, sync results, and refresh activity. It is the first place to check when something fails."/>
                    </StackPanel>
                    <RichTextBox x:Name="StatusRichTextBox"
                                 Margin="0,12,0,0"
                                 Height="220"
                                 Style="{StaticResource StatusLogStyle}"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,6">
                <Button Width="120"
                        Content="Save Connection"
                        Margin="0,0,8,0"
                        Style="{StaticResource ModernButton}"
                        Click="SaveConnectionButton_Click"
                        ToolTip="Persist this connection profile so it stays available in The Oceanyan File Hivemind across app restarts."/>
                <Button Width="100"
                        Content="Close"
                        Style="{StaticResource ModernButton}"
                        Click="CloseButton_Click"
                        ToolTip="Close this connection editor and return to the previous screen."/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</local:OceanyaWindowContentControl>
