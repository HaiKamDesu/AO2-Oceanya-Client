<local:OceanyaWindowContentControl x:Class="OceanyaClient.OceanyanFileHivemindWindow"
                                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                   xmlns:local="clr-namespace:OceanyaClient"
                                   Width="1080"
                                   Height="780"
                                   MinWidth="900"
                                   MinHeight="660"
                                   Background="Transparent">
    <local:OceanyaWindowContentControl.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D3D" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF171717" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FF1A1A1A" TargetName="ButtonBorder"/>
                                <Setter Property="BorderBrush" Value="#FF333333" TargetName="ButtonBorder"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BodyHintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFBEBEBE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#C8181818"/>
            <Setter Property="BorderBrush" Value="#FF363636"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="StatusLogStyle" TargetType="RichTextBox">
            <Setter Property="Background" Value="#FF171717"/>
            <Setter Property="Foreground" Value="#FFE7E7E7"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsDocumentEnabled" Value="False"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style x:Key="SelectableInfoTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style x:Key="HelpBadgeStyle" TargetType="Button">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFBDBDBD"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="120"/>
            <Setter Property="ToolTipService.ShowDuration" Value="600000"/>
            <Setter Property="ToolTipService.Placement" Value="Right"/>
            <Setter Property="ToolTipService.HorizontalOffset" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#FF1C1C1C"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="BorderBrush" Value="#FF4A4A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="460"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   MaxWidth="430"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConnectionListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#FF171717"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SectionCardStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="THE OCEANYAN FILE HIVEMIND"
                               Style="{StaticResource SectionTitleText}"/>
                    <Button Content="(?)"
                            Style="{StaticResource HelpBadgeStyle}"
                            ToolTip="This manager stores multiple remote asset connections. Right now it supports Google Drive, but the saved model is provider-ready for more backends later."/>
                </StackPanel>
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource BodyHintText}"
                           Text="Use this as the connection database: add as many remote folders/accounts as you need, export a connection file for friends, import shared connection files, then sync one or all connections from here. Hosts set up the Google Cloud Desktop app once per connection; importing users only need to sign into Google."/>
                <CheckBox x:Name="RunAtStartupCheckBox"
                          Margin="0,12,0,0"
                          Foreground="#FFF0F0F0"
                          Checked="RunAtStartupCheckBox_Changed"
                          Unchecked="RunAtStartupCheckBox_Changed"
                          Content="Run hidden Hivemind sync agent automatically when Windows starts"
                          ToolTip="When enabled, Oceanya registers a per-user startup entry so the hidden Hivemind sync agent launches after Windows sign-in and keeps your configured connections in sync even if the main Oceanya window is closed."/>
                <CheckBox x:Name="DesktopToastsCheckBox"
                          Margin="0,8,0,0"
                          Foreground="#FFF0F0F0"
                          Checked="DesktopToastsCheckBox_Changed"
                          Unchecked="DesktopToastsCheckBox_Changed"
                          Content="Show desktop toast popups for important background sync events"
                          ToolTip="When enabled, the Hivemind tray agent shows a small Oceanya-styled desktop toast for important success, warning, and error events. Routine polling still stays silent."/>
                <StackPanel Margin="0,12,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Remote poll interval (seconds)"
                               Foreground="#FFD4D4D4"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button Content="(?)"
                            Style="{StaticResource HelpBadgeStyle}"
                            ToolTip="How often the background agent checks Google Drive for remote changes. Lower values react faster but do more network work. Minimum 5 seconds."/>
                    <TextBox x:Name="RemotePollIntervalTextBox"
                             Width="72"
                             Margin="12,0,0,0"
                             Style="{StaticResource ModernTextBox}"
                             HorizontalContentAlignment="Center"
                             LostFocus="RemotePollIntervalTextBox_LostFocus"
                             KeyDown="RemotePollIntervalTextBox_KeyDown"
                             ToolTip="Enter how many seconds Oceanya should wait between Google Drive change-token polls while the background agent is running."/>
                </StackPanel>
                <TextBlock x:Name="BackgroundAgentStatusTextBlock"
                           Margin="0,8,0,0"
                           Style="{StaticResource BodyHintText}"
                           Text="Background sync agent status unavailable."/>
                <StackPanel Margin="0,12,0,0"
                            Orientation="Horizontal">
                    <Button x:Name="BackgroundAgentSessionButton"
                            MinWidth="170"
                            Style="{StaticResource ModernButton}"
                            Click="BackgroundAgentSessionButton_Click"
                            Content="Launch Agent Now"/>
                    <TextBlock Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource BodyHintText}"
                               Text="This controls the hidden agent for the current Windows session without changing your saved startup preference."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CONNECTIONS"
                                       Style="{StaticResource SectionTitleText}"/>
                            <Button Content="(?)"
                                    Style="{StaticResource HelpBadgeStyle}"
                                    ToolTip="Each saved connection points at one remote asset store and one local mirror folder. Multiple Google accounts and multiple folders can coexist here."/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyHintText}"
                                   Text="Select a connection to see details or run targeted sync actions."/>
                    </StackPanel>

                    <ListBox x:Name="ConnectionsListBox"
                             Grid.Row="1"
                             Margin="0,12,0,12"
                             Style="{StaticResource ConnectionListBoxStyle}"
                             SelectionChanged="ConnectionsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#AA202020"
                                        BorderBrush="#FF343434"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Connection.EffectiveDisplayName}"
                                                   Foreground="{Binding PrimaryForeground}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{Binding SecondaryForeground}"
                                                   Text="{Binding Connection.ProviderDisplayName}"/>
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="{Binding SecondaryForeground}"
                                                   Text="{Binding Connection.AccountDisplayName}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="{Binding SecondaryForeground}"
                                                   Text="{Binding Connection.RemoteDisplayName}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{Binding SecondaryForeground}"
                                                   FontStyle="Italic"
                                                   Text="{Binding StatusText}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2"
                                HorizontalAlignment="Center">
                        <WrapPanel HorizontalAlignment="Center">
                            <Button Width="100"
                                    Content="Add"
                                    Style="{StaticResource ModernButton}"
                                    Click="AddDriveConnectionButton_Click"
                                    ToolTip="Create a new Google Drive connection profile and open its editor popup. The host can then paste the Google Cloud Desktop app client ID and client secret for that connection."/>
                            <Button Width="100"
                                    Margin="8,0,0,0"
                                    Content="Edit"
                                    Style="{StaticResource ModernButton}"
                                    Click="EditConnectionButton_Click"
                                    ToolTip="Open the selected connection in the provider-specific editor popup."/>
                            <Button Width="100"
                                    Margin="8,0,0,0"
                                    Content="Delete"
                                    Style="{StaticResource ModernButton}"
                                    Click="DeleteConnectionButton_Click"
                                    ToolTip="Remove the selected connection from the local hivemind database and clear its saved Google token."/>
                        </WrapPanel>

                        <WrapPanel Margin="0,8,0,0"
                                   HorizontalAlignment="Center">
                            <Button Width="100"
                                    Content="Import"
                                    Style="{StaticResource ModernButton}"
                                    Click="ImportConnectionButton_Click"
                                    ToolTip="Import a shared hivemind connection file, including the remote folder settings and an obfuscated copy of that connection's Google Cloud app credentials. You still sign into your own Google account, but you do not need to open Google Cloud Console on this machine."/>
                            <Button Width="100"
                                    Margin="8,0,0,0"
                                    Content="Export"
                                    Style="{StaticResource ModernButton}"
                                    Click="ExportConnectionButton_Click"
                                    ToolTip="Export the selected connection into a shareable file that includes an obfuscated copy of the Google Cloud app credentials for that connection, but never includes any user's Google login tokens, saved local token files, or the local mirror path. Share exported files only with intended participants."/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SELECTED CONNECTION"
                                       Style="{StaticResource SectionTitleText}"/>
                            <Button Content="(?)"
                                    Style="{StaticResource HelpBadgeStyle}"
                                    ToolTip="This shows the currently selected connection's provider, signed-in account, remote folder, local mirror, and last sync time."/>
                        </StackPanel>

                        <TextBlock Text="NAME"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionNameTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"
                                 Foreground="White"/>

                        <TextBlock Text="PROVIDER"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionProviderTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"/>

                        <TextBlock Text="ACCOUNT"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionAccountTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"/>

                        <TextBlock Text="REMOTE FOLDER"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionRemoteTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"/>

                        <TextBlock Text="LOCAL MIRROR"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionLocalTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"
                                 ToolTip="Double-click the local mirror path to open it in the system file explorer."
                                 PreviewMouseDoubleClick="SelectedConnectionLocalTextBox_PreviewMouseDoubleClick"/>

                        <TextBlock Text="LAST SYNC"
                                   Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="SelectedConnectionLastSyncTextBlock"
                                 Style="{StaticResource SelectableInfoTextBox}"/>

                        <WrapPanel Margin="0,14,0,0"
                                   HorizontalAlignment="Center">
                            <Button Width="140"
                                    Content="Sync From Drive"
                                    Style="{StaticResource ModernButton}"
                                    Click="PullSelectedButton_Click"
                                    ToolTip="Pull only the selected connection from Drive into its local mirror folder."/>
                            <Button Width="140"
                                    Margin="8,0,0,0"
                                    Content="Push To Drive"
                                    Style="{StaticResource ModernButton}"
                                    Click="PushSelectedButton_Click"
                                    ToolTip="Push only the selected connection's local mirror folder back to Drive."/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center">
                            <CheckBox x:Name="SelectedConnectionAutoSyncCheckBox"
                                      Foreground="#FFF0F0F0"
                                      Checked="SelectedConnectionAutoSyncCheckBox_Changed"
                                      Unchecked="SelectedConnectionAutoSyncCheckBox_Changed"
                                      Content="Auto-sync enabled for this connection"/>
                            <Button Content="(?)"
                                    Style="{StaticResource HelpBadgeStyle}"
                                    ToolTip="When enabled, the hidden Hivemind background agent can poll and sync this connection automatically. Manual Sync From Drive and Push To Drive still work when this is off."/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SYNC ACTIONS"
                                       Style="{StaticResource SectionTitleText}"/>
                            <Button Content="(?)"
                                    Style="{StaticResource HelpBadgeStyle}"
                                    ToolTip="Use these buttons for the selected connection or to pull every saved connection in sequence."/>
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource BodyHintText}"
                                   Text="These buttons act on the whole list at once. Use the selected connection section above for one specific folder."/>

                        <WrapPanel Margin="0,12,0,0">
                            <Button Width="140"
                                    Content="Ensure Mount Path"
                                    Style="{StaticResource ModernButton}"
                                    Click="EnsureMountPathButton_Click"
                                    ToolTip="Make sure the selected connection's local mirror folder exists in AO's mount_paths."/>
                            <Button Width="140"
                                    Margin="8,0,0,0"
                                    Content="Sync All From Drive"
                                    Style="{StaticResource ModernButton}"
                                    Click="PullAllButton_Click"
                                    ToolTip="Pull every saved connection from Drive in sequence and refresh only the changed AO assets."/>
                            <Button Width="140"
                                    Margin="8,0,0,0"
                                    Content="Push All To Drive"
                                    Style="{StaticResource ModernButton}"
                                    Click="PushAllButton_Click"
                                    ToolTip="Push every saved connection's local mirror folder back to Drive in sequence."/>
                            <Button Width="140"
                                    Margin="8,0,0,0"
                                    Content="Refresh AO Assets"
                                    Style="{StaticResource ModernButton}"
                                    Click="RefreshAssetsButton_Click"
                                    ToolTip="Run the full AO asset refresh manually if you need a complete rebuild outside targeted sync refreshes."/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource SectionCardStyle}"
                        Margin="0,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="STATUS LOG"
                                       Style="{StaticResource SectionTitleText}"/>
                            <Button Content="(?)"
                                    Style="{StaticResource HelpBadgeStyle}"
                                    ToolTip="Open a larger popup log with connection edits, sync progress, mount-path updates, and any warnings or failures from the hivemind manager."/>
                        </StackPanel>
                        <Button Width="170"
                                Margin="0,8,0,0"
                                Content="Open Status Log"
                                HorizontalAlignment="Left"
                                Style="{StaticResource ModernButton}"
                                Click="OpenStatusLogButton_Click"
                                ToolTip="Open the larger status log popup for this hivemind session."/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="100"
                    Content="Close"
                    Style="{StaticResource ModernButton}"
                    Click="CloseButton_Click"
                    ToolTip="Close The Oceanyan File Hivemind and return to the previous screen."/>
        </StackPanel>
    </Grid>
</local:OceanyaWindowContentControl>
