<UserControl x:Class="OceanyaClient.Features.Viewport.AO2ViewportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:OceanyaClient"
             Width="256"
             Height="296"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid Width="256" Height="296" Background="Transparent" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="192"/>
            <RowDefinition Height="104"/>
        </Grid.RowDefinitions>

        <Canvas x:Name="ViewportCanvas" Grid.Row="0" Width="256" Height="192" Background="Black" ClipToBounds="True">
            <!-- ViewportFallbackImage: static layer shown when bg is transparent/absent. Set Source here to use a custom fallback image. -->
            <Image x:Name="ViewportFallbackImage" Width="256" Height="192" Stretch="Fill" Panel.ZIndex="0" Source="pack://application:,,,/OceanyaClient;component/Resources/ViewportFallback.png"/>
            <Image x:Name="BackgroundImage" Width="256" Height="192" Stretch="Fill" Panel.ZIndex="1"/>
            <Image x:Name="SpeedlinesImage" Width="256" Height="192" Stretch="Fill" Visibility="Collapsed" Panel.ZIndex="1"/>
            <Image x:Name="CharacterImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="4"/>
            <Image x:Name="PairCharacterImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="3"/>
            <Image x:Name="DeskImage" Width="256" Height="192" Stretch="Fill" Visibility="Collapsed" Panel.ZIndex="5"/>
            <Image x:Name="EffectImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="8"/>
            <Image x:Name="ShoutOverlayImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="9"/>
            <Image x:Name="StickerImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="6"/>
            <Image x:Name="EvidenceImage" Width="48" Height="48" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="9"/>
            <Image x:Name="TestimonyImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="11"/>
            <Image x:Name="WtceImage" Width="256" Height="192" Stretch="Uniform" Visibility="Collapsed" Panel.ZIndex="12"/>
            <Border x:Name="FlashOverlay"
                    Width="256"
                    Height="192"
                    Background="White"
                    Opacity="0"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Panel.ZIndex="10"/>
        </Canvas>

        <components:AO2ChatPreviewControl x:Name="ChatPreview"
                                          Grid.Row="1"
                                          Width="256"
                                          Height="104"
                                          ShowPreviewHeader="False"
                                          UseNativeViewportLayout="True"
                                          Visibility="Collapsed"
                                          IsHitTestVisible="True"/>

        <Canvas Grid.Row="1" Width="256" Height="104" IsHitTestVisible="False">
            <Image x:Name="ChatArrowImage"
                   Canvas.Left="245"
                   Canvas.Top="84"
                   Width="11"
                   Height="9"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</UserControl>
