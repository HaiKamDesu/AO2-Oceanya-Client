<local:OceanyaWindowContentControl x:Class="OceanyaClient.Features.Viewport.AO2ViewportWindowContent"
                                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                   xmlns:local="clr-namespace:OceanyaClient"
                                   xmlns:viewport="clr-namespace:OceanyaClient.Features.Viewport"
                                   MinWidth="256"
                                   MinHeight="296"
                                   ShowInTaskbar="False"
                                   Title="AO2 Viewport">
    <Grid Background="Transparent" ClipToBounds="True">
        <Viewbox Stretch="Uniform"
                 StretchDirection="Both"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 SnapsToDevicePixels="True">
            <Grid x:Name="ViewportHost"
                  Width="256"
                  Height="296"/>
        </Viewbox>
    </Grid>
</local:OceanyaWindowContentControl>
