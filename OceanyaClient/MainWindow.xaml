<local:OceanyaWindowContentControl x:Class="OceanyaClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OceanyaClient"
        xmlns:components="clr-namespace:OceanyaClient.Components"
        Height="652" Width="510"
        Background="Transparent">

    <!-- 
      1) Copy over any resources from your InitialConfigurationWindow that 
         define the close button style, text styles, animations, etc.
      2) You can omit or customize these if you do not need them for MainWindow.
    -->
    <local:OceanyaWindowContentControl.Resources>
        <!-- Button style with a dark overlay on hover and press -->
        <Style x:Key="ModernButton" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FF262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF3D3D3D" TargetName="ButtonBorder"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF171717" TargetName="ButtonBorder"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Optional fade-in/out storyboards if you like:
             (Only needed if you want the same fade effect as in InitialConfigurationWindow) -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <Style x:Key="DreddRowButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Background" Value="#FF1F1F1F"/>
            <Setter Property="BorderBrush" Value="#FF4A4A4A"/>
        </Style>

        <Style x:Key="DreddRowCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#FFE5E5E5"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="DreddRowListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2D3C4A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF36506A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#FF181C20"/>
            <Setter Property="BorderBrush" Value="#FF3E5362"/>
        </Style>

        <Style x:Key="PopupCommandButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#FF20262B"/>
            <Setter Property="BorderBrush" Value="#FF4A5963"/>
        </Style>

        <Style x:Key="DarkPopupListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="#FFE8E8E8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222F4553"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#334D6A7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkPopupCheckBoxStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="#FFE6E6E6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </local:OceanyaWindowContentControl.Resources>

    <!-- Optional fade-in trigger (remove if not desired) -->
    <local:OceanyaWindowContentControl.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </local:OceanyaWindowContentControl.Triggers>

    <local:OceanyaWindowContentControl.Opacity>1</local:OceanyaWindowContentControl.Opacity>

    <!-- Outer border for the "rounded corners + black outline" look -->
    <Border BorderBrush="#222222" BorderThickness="1" CornerRadius="5">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="ConnectionInfoBar"
                    Grid.Row="0"
                    Background="#FF090B0E"
                    BorderBrush="#FF252525"
                    BorderThickness="0,0,0,1"
                    SizeChanged="ConnectionInfoBar_SizeChanged">
                <WrapPanel Margin="4,2,4,2" Orientation="Horizontal">

                    <Border x:Name="ServerChip" Margin="0,1,4,1" CornerRadius="3" Background="#FF171B21" BorderBrush="#FF2D3744" BorderThickness="1">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="SERVER" DockPanel.Dock="Left" Foreground="#FF7FA8D8" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedServerInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Server"
                                       Text="Disconnected"
                                       Foreground="#FFE8E8E8"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="AreaChip" Margin="0,1,4,1" CornerRadius="3" Background="#FF151D18" BorderBrush="#FF284332" BorderThickness="1">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="AREA" DockPanel.Dock="Left" Foreground="#FF89C796" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedAreaInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Area"
                                       Text="Unknown"
                                       Foreground="#FFE8E8E8"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="UsersChip" Margin="0,1,4,1" CornerRadius="3" Background="#FF211B13" BorderBrush="#FF4B3B20" BorderThickness="1">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="USERS" DockPanel.Dock="Left" Foreground="#FFD9B56D" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedAreaUsersInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Users"
                                       Text="-"
                                       Foreground="#FFF0E7D2"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="StatusChip" Margin="0,1,4,1" CornerRadius="3" Background="#FF181520" BorderBrush="#FF352C4A" BorderThickness="1" Visibility="Collapsed">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="STATUS" DockPanel.Dock="Left" Foreground="#FFAA88DD" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedAreaStatusInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Status"
                                       Text="-"
                                       Foreground="#FFE8E8E8"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="LockChip" Margin="0,1,4,1" CornerRadius="3" Background="#FF1D1515" BorderBrush="#FF4A2828" BorderThickness="1" Visibility="Collapsed">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="LOCK" DockPanel.Dock="Left" Foreground="#FFDD8888" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedAreaLockInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Lock"
                                       Text="-"
                                       Foreground="#FFE8E8E8"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <Border x:Name="CmChip" Margin="0,1,0,1" CornerRadius="3" Background="#FF1C1720" BorderBrush="#FF3C3148" BorderThickness="1" Visibility="Collapsed">
                        <DockPanel Margin="5,1">
                            <TextBlock Text="CM" DockPanel.Dock="Left" Foreground="#FFC0A1D8" FontSize="8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="txtSelectedAreaMetaInfo"
                                       AutomationProperties.AutomationId="Main.ConnectionInfo.Meta"
                                       Text="-"
                                       Foreground="#FFE8E8E8"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                </WrapPanel>
            </Border>

            <!-- Optional body background treatment. -->
                <Rectangle x:Name="imgScienceBlur" 
                       Grid.Row="1"
                       HorizontalAlignment="Center" Width="527" Height="670" 
                       VerticalAlignment="Top" Margin="0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="pack://application:,,,/OceanyaClient;component/Resources/scoienceblur.jpg" Opacity="0.5"/>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle x:Name="imgScienceBlur_darken"
                       Grid.Row="1"
                       HorizontalAlignment="Center" Width="527" Height="670" 
                       VerticalAlignment="Top" Margin="0" Fill="#7F000000"/>

                <Rectangle HorizontalAlignment="Center" Width="369" Height="276"
                       Grid.Row="1"
                       VerticalAlignment="Top" Margin="0,-21,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="pack://application:,,,/OceanyaClient;component/Resources/Logo_O.png" Stretch="Uniform" Opacity="0.1"/>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Main body content only; shared window chrome comes from GenericOceanyaWindow. -->
            <Canvas x:Name="MainCanvas" Grid.Row="1" Margin="0" Background="#FF585858">
                <!-- Entire original body content lives here. -->


                <Rectangle x:Name="bgRectangleOOC" Height="333" Canvas.Left="287" Width="222" Fill="#FF8B8B8B"/>
                <components:OOCLog x:Name="OOCLogControl" DockPanel.Dock="Top" Height="298" Canvas.Left="287" Width="222"/>

                <Rectangle Height="18" Canvas.Left="426" Canvas.Top="318" Width="83" Fill="#FF4E5056" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                <DockPanel x:Name="Dock_ICLog" Height="323" Width="232" Canvas.Left="55">
                    <DockPanel.Background>
                        <ImageBrush ImageSource="pack://application:,,,/OceanyaClient;component/Resources/LogBG.png"/>
                    </DockPanel.Background>
                </DockPanel>
                <components:ICLog x:Name="ICLogControl" DockPanel.Dock="Top" Height="298" Width="228" Canvas.Left="59" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Image x:Name="imgShoutModifierBG" Height="42" Canvas.Left="2" Canvas.Top="296" Width="428" Source="pack://application:,,,/OceanyaClient;component/Resources/ObjectionButtonsBG.png" Stretch="None"/>
                <ToggleButton x:Name="HoldIt" Height="40" Width="102" Canvas.Left="4" Canvas.Top="298"
                              AutomationProperties.AutomationId="Main.Shout.HoldIt"
                              AutomationProperties.Name="Hold It"
                              BorderBrush="{x:Null}" HorizontalAlignment="Left" VerticalAlignment="Top"
                              Padding="0,0,0,0" Checked="ToggleButton_Checked"
                              Focusable="False" IsTabStop="False">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Hold It.png"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Hold It_Selected.png"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <ToggleButton x:Name="Objection" Height="40" Width="102" Canvas.Left="111" Canvas.Top="298"
                              AutomationProperties.AutomationId="Main.Shout.Objection"
                              AutomationProperties.Name="Objection"
                              BorderBrush="{x:Null}" Padding="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                              Checked="ToggleButton_Checked"
                              Focusable="False" IsTabStop="False">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Objection.png"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Objection_Selected.png"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <ToggleButton x:Name="TakeThat" Height="40" Width="102" Canvas.Left="218" Canvas.Top="298"
                              AutomationProperties.AutomationId="Main.Shout.TakeThat"
                              AutomationProperties.Name="Take That"
                              BorderBrush="{x:Null}" Padding="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"
                              Checked="ToggleButton_Checked"
                              Focusable="False" IsTabStop="False">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Take That.png"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Take That_Selected.png"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <ToggleButton x:Name="Custom" Height="40" Width="102" Canvas.Left="324" Canvas.Top="298"
                              AutomationProperties.AutomationId="Main.Shout.Custom"
                              AutomationProperties.Name="Custom"
                              BorderBrush="{x:Null}" Padding="0,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                              Checked="ToggleButton_Checked"
                              Focusable="False" IsTabStop="False">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Custom.png"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Source" Value="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Custom_Selected.png"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>

                <Button x:Name="btnAddClient" Height="24" Width="24" BorderBrush="{x:Null}" Foreground="{x:Null}" Padding="0"
                        AutomationProperties.AutomationId="Main.AddClient"
                        AutomationProperties.Name="Add Client"
                        HorizontalAlignment="Center" VerticalAlignment="Top"
                        Click="btnAddClient_Click" Canvas.Left="2" Canvas.Top="24">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Plus.png" Stretch="Fill"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnRemoveClient" Height="24" Width="24" BorderBrush="{x:Null}" Foreground="{x:Null}" Padding="0"
                        AutomationProperties.AutomationId="Main.RemoveClient"
                        AutomationProperties.Name="Remove Client"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Click="btnRemoveClient_Click" Canvas.Left="28" Canvas.Top="24">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Minus.png" Stretch="Fill"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <components:PageButtonGrid x:Name="EmoteGrid" Canvas.Left="2" Canvas.Top="48" BorderBrush="#FF545454" 
                                           Background="DimGray" BorderThickness="1" Width="50" Height="248"/>

                <Label x:Name="lblClients" Content="Clients" Height="24" Width="46" 
                       FontFamily="pack://application:,,,/Resources/Fonts/#Igiari Cyrillic" Foreground="White" 
                       Canvas.Left="4" Canvas.Top="2"/>

                <components:ICMessageSettings x:Name="ICMessageSettingsControl" Canvas.Top="343" 
                                              Width="509" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Rectangle x:Name="FeatureRowBackground" Height="30" Canvas.Top="603" Width="509" Fill="#FF1B1C1F" Visibility="Collapsed"/>
                <TextBlock x:Name="DreddFeatureLabel"
                           Text="Dredd's Background&#x0a;Overlay Override"
                           Canvas.Left="8"
                           Canvas.Top="606"
                           Width="108"
                           TextWrapping="Wrap"
                           ToolTip="Dredd's Background Overlay Override"
                           Foreground="#FFE8E8E8"
                           FontSize="8.5"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <Grid x:Name="DreddOverlaySelector"
                      Canvas.Left="120"
                      Canvas.Top="607"
                      Width="170"
                      Height="22"
                      Visibility="Collapsed">
                    <Border Background="#FF1E1E1E" BorderBrush="#FF4A4A4A" BorderThickness="1" CornerRadius="2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DreddOverlaySelectedText"
                                   Grid.Column="0"
                                   Margin="6,0,2,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="#FFE8E8E8"
                                   FontSize="10"/>
                        <Button x:Name="DreddOverlayDropButton"
                                Grid.Column="1"
                                Background="#00000000"
                                BorderThickness="0"
                                Foreground="#FFE8E8E8"
                                FontSize="10"
                                Content="▼"
                                Click="DreddOverlayDropButton_Click"/>
                    </Grid>
                </Grid>
                <Popup x:Name="DreddOverlayPopup"
                       PlacementTarget="{Binding ElementName=DreddOverlaySelector}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Width="260" MaxHeight="220" Background="#FF1E1E1E" BorderBrush="#FF4A4A4A" BorderThickness="1" CornerRadius="2">
                        <ListBox x:Name="DreddOverlayListBox"
                                 Background="#FF1E1E1E"
                                 BorderThickness="0"
                                 Foreground="#FFE8E8E8"
                                 FontSize="10"
                                 SelectionChanged="DreddOverlayListBox_SelectionChanged"
                                 ItemContainerStyle="{StaticResource DreddRowListItemStyle}"/>
                    </Border>
                </Popup>
                <CheckBox x:Name="DreddStickyOverlayCheckBox"
                          Content="Sticky overlay"
                          Canvas.Left="294"
                          Canvas.Top="609"
                          Style="{StaticResource DreddRowCheckBoxStyle}"
                          Checked="DreddStickyOverlayCheckBox_Checked"
                          Unchecked="DreddStickyOverlayCheckBox_Checked"
                          Visibility="Collapsed"/>
                <Button x:Name="DreddOverlayConfigButton"
                        Content="Config"
                        Canvas.Left="376"
                        Canvas.Top="607"
                        Width="40"
                        Height="22"
                        Style="{StaticResource DreddRowButtonStyle}"
                        Click="DreddOverlayConfigButton_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="DreddViewChangesButton"
                        Content="View Changes"
                        Canvas.Left="418"
                        Canvas.Top="607"
                        Width="87"
                        Height="22"
                        Style="{StaticResource DreddRowButtonStyle}"
                        Click="DreddViewChangesButton_Click"
                        Visibility="Collapsed"/>

                <Rectangle x:Name="BottomStatusBar" Height="24" Canvas.Top="603" Width="509" Fill="#FF36393F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <CheckBox x:Name="chkSticky" Content="Sticky Effects" 
                          AutomationProperties.AutomationId="Main.Options.StickyEffects"
                          Canvas.Top="607" Foreground="White" FontFamily="Arial" FontSize="10" 
                          Width="82" Height="16" BorderBrush="Black" 
                          Checked="chkStickyEffects_Checked" Unchecked="chkStickyEffects_Checked" 
                          Canvas.Left="10" Focusable="False" IsTabStop="False" VerticalContentAlignment="Center"
                          Visibility="Collapsed"/>

                <Button x:Name="btnRefreshCharacters" Height="24" Width="24" 
                        AutomationProperties.AutomationId="Main.OpenCharacterFolderVisualizer"
                        AutomationProperties.Name="Open Character Folder Visualizer"
                        BorderBrush="{x:Null}" Foreground="{x:Null}" Padding="0"
                        Canvas.Left="377" Canvas.Top="603"
                        Click="btnCharacterFolderVisualizer_Click"
                        ToolTip="Character Folder Visualizer">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid>
                                            <Image x:Name="ButtonImage" Source="pack://application:,,,/OceanyaClient;component/Resources/Buttons/smallFolder.png" Stretch="Fill"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnSettings"
                        Height="24"
                        Width="24"
                        Canvas.Left="485"
                        Canvas.Top="603"
                        AutomationProperties.AutomationId="Main.Settings.Open"
                        AutomationProperties.Name="Open Settings"
                        BorderBrush="{x:Null}"
                        Foreground="#FFE8E8E8"
                        Padding="0"
                        Click="btnSettings_Click"
                        ToolTip="Settings">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid>
                                            <TextBlock x:Name="ButtonGlyph"
                                                       Text="&#xE713;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{TemplateBinding Foreground}"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonGlyph" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonGlyph" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <CheckBox x:Name="chkPosOnIniSwap" Content="Switch Pos on INISwap" 
                          AutomationProperties.AutomationId="Main.Options.SwitchPosOnIniSwap"
                          Canvas.Top="607" Foreground="White" FontFamily="Arial" FontSize="10" 
                          Width="127" Height="16" BorderBrush="Black" 
                          Checked="chkPosOnIniSwap_Checked" Unchecked="chkPosOnIniSwap_Checked" 
                          Canvas.Left="97" Focusable="False" IsTabStop="False" VerticalContentAlignment="Center"
                          Visibility="Collapsed"/>

                <Button x:Name="btnDebug" Content="Button" Height="18" 
                        Canvas.Left="442" Canvas.Top="607" Width="38" 
                        Click="Button_Click" Visibility="Collapsed"/>
                <CheckBox x:Name="chkInvertLog" Content="Invert IC Logs" 
                    AutomationProperties.AutomationId="Main.Options.InvertIcLogs"
                    Canvas.Top="607" Foreground="White" FontFamily="Arial" FontSize="10" 
                    Width="127" Height="16" BorderBrush="Black" 
                    Checked="chkInvertLog_Checked" Unchecked="chkInvertLog_Checked" 
                    Canvas.Left="229" Focusable="False" IsTabStop="False" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top"
                    Visibility="Collapsed"/>

                <Button x:Name="btnAreaNavigator"
                        AutomationProperties.AutomationId="Main.AreaNavigator.Open"
                        AutomationProperties.Name="Area Navigator"
                        Canvas.Left="431"
                        Canvas.Top="603"
                        Content="A"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="btnAreaNavigator_Click"
                        ToolTip="Area Navigator"/>

                <Button x:Name="btnMusicList"
                        AutomationProperties.AutomationId="Main.MusicList.Open"
                        AutomationProperties.Name="Music List"
                        Canvas.Left="458"
                        Canvas.Top="603"
                        Content="M"
                        Style="{StaticResource CompactIconButtonStyle}"
                        Click="btnMusicList_Click"
                        ToolTip="Music List"/>

                <Button x:Name="btnViewport"
                        AutomationProperties.AutomationId="Main.Viewport.Open"
                        AutomationProperties.Name="Open AO2 Viewport"
                        Width="24"
                        Height="24"
                        Canvas.Left="404"
                        Canvas.Top="603"
                        Content="V"
                        FontWeight="Bold"
                        Click="btnViewport_Click"
                        ToolTip="AO2 Viewport"/>

                <Popup x:Name="AreaNavigatorPopup"
                       AutomationProperties.AutomationId="Main.AreaNavigator.Popup"
                       PlacementTarget="{Binding ElementName=btnAreaNavigator}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#FF202020"
                            BorderBrush="#FF3E5362"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                        <Grid x:Name="AreaNavigatorPopupSurface"
                              MinWidth="220"
                              MinHeight="220"
                              Width="282"
                              Height="296">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.RowSpan="4" Background="#E6111418"/>
                            <TextBlock Text="Area Navigator" Foreground="White" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtCurrentArea"
                                       Grid.Row="1"
                                       AutomationProperties.AutomationId="Main.AreaNavigator.CurrentArea"
                                       Text="Current: Unknown"
                                       Foreground="#FFD5E6F0"
                                       Margin="0,0,0,6"/>
                            <ListBox x:Name="lstAreas"
                                     Grid.Row="2"
                                     AutomationProperties.AutomationId="Main.AreaNavigator.List"
                                     Margin="0,0,0,6"
                                     Background="#FF11161A"
                                     BorderBrush="#FF2F434E"
                                     Foreground="#FFE8E8E8"
                                     ItemContainerStyle="{StaticResource DarkPopupListBoxItemStyle}"
                                     MouseDoubleClick="lstAreas_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,4"
                                                Padding="6,4"
                                                CornerRadius="2"
                                                Background="{Binding RowBackground}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           Foreground="#FFF2F2F2"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusAndCmLine}"
                                                           Margin="0,2,0,0"
                                                           Foreground="#FFE8E8E8"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding PlayersAndLockLine}"
                                                           Margin="0,1,0,0"
                                                           Foreground="#FFE8E8E8"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnGoToArea"
                                        AutomationProperties.AutomationId="Main.AreaNavigator.Go"
                                        Content="Go"
                                        Style="{StaticResource PopupCommandButtonStyle}"
                                        Click="btnGoToArea_Click"/>
                            </StackPanel>
                            <Thumb Grid.RowSpan="4"
                                   Width="5"
                                   HorizontalAlignment="Right"
                                   Cursor="SizeWE"
                                   Background="Transparent"
                                   Opacity="0"
                                   Margin="0,-10,-10,-10"
                                   DragDelta="AreaNavigatorRightResizeThumb_DragDelta"
                                   DragCompleted="PopupResizeThumb_DragCompleted"/>
                            <Thumb Grid.RowSpan="4"
                                   Height="5"
                                   VerticalAlignment="Top"
                                   Cursor="SizeNS"
                                   Background="Transparent"
                                   Opacity="0"
                                   Margin="-10,-10,-10,0"
                                   DragDelta="AreaNavigatorTopResizeThumb_DragDelta"
                                   DragCompleted="PopupResizeThumb_DragCompleted"/>
                            <Thumb Grid.RowSpan="4"
                                   Width="14"
                                   Height="14"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   Cursor="SizeNESW"
                                   Background="Transparent"
                                   Opacity="0"
                                   Margin="0,-10,-10,0"
                                   DragDelta="AreaNavigatorTopRightResizeThumb_DragDelta"
                                   DragCompleted="PopupResizeThumb_DragCompleted"/>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="MusicListPopup"
                       AutomationProperties.AutomationId="Main.MusicList.Popup"
                       PlacementTarget="{Binding ElementName=btnMusicList}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#FF202020"
                            BorderBrush="#FF3E5362"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10">
                        <Grid x:Name="MusicListPopupSurface"
                              MinWidth="260"
                              MinHeight="300"
                              Width="320"
                              Height="420">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.RowSpan="5" Background="#E6111418"/>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Music List" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button x:Name="btnRefreshMusicList"
                                            AutomationProperties.AutomationId="Main.MusicList.Refresh"
                                            Content="Refresh"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource PopupCommandButtonStyle}"
                                            Click="btnRefreshMusicList_Click"/>
                                </DockPanel>
                                <TextBox x:Name="txtMusicSearch"
                                         Grid.Row="1"
                                         AutomationProperties.AutomationId="Main.MusicList.Search"
                                         Height="26"
                                         Margin="0,0,0,6"
                                         Padding="7,3"
                                         Background="#FF1C2227"
                                         BorderBrush="#FF3E5362"
                                         Foreground="#FFE8E8E8"
                                         TextChanged="txtMusicSearch_TextChanged"/>
                                <TreeView x:Name="treeMusic"
                                         PreviewMouseRightButtonDown="treeMusic_PreviewMouseRightButtonDown"
                                         Grid.Row="2"
                                         AutomationProperties.AutomationId="Main.MusicList.List"
                                         Margin="0,0,0,8"
                                         Background="#FF11161A"
                                         BorderBrush="#FF2F434E"
                                         Foreground="#FFE8E8E8"
                                         MouseDoubleClick="treeMusic_MouseDoubleClick"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         ScrollViewer.CanContentScroll="True">
                                    <TreeView.ContextMenu>
                                        <ContextMenu Opened="MusicContextMenu_Opened">
                                            <MenuItem Header="Stop Current Song" Click="MusicStopMenuItem_Click"/>
                                            <MenuItem Header="Play Random Song" Click="MusicRandomMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem Header="Expand All Categories" Click="MusicExpandAllMenuItem_Click"/>
                                            <MenuItem Header="Collapse All Categories" Click="MusicCollapseAllMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem x:Name="menuMusicShowAssetPaths" Header="Show Asset Paths" IsCheckable="True" IsChecked="False" Click="MusicShowAssetPathsMenuItem_Click"/>
                                            <Separator/>
                                            <MenuItem x:Name="menuMusicFadeOut" Header="Fade Out Previous" IsCheckable="True" IsChecked="True" Click="MusicFlagMenuItem_Click"/>
                                            <MenuItem x:Name="menuMusicFadeIn" Header="Fade In" IsCheckable="True" Click="MusicFlagMenuItem_Click"/>
                                            <MenuItem x:Name="menuMusicSync" Header="Synchronize" IsCheckable="True" Click="MusicFlagMenuItem_Click"/>
                                            <Separator x:Name="sepMusicFrequent" Visibility="Collapsed"/>
                                            <MenuItem x:Name="menuMusicRemoveFrequent" Header="Remove from Frequently Used" Visibility="Collapsed" Click="MusicRemoveFrequentMenuItem_Click"/>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="{x:Type TreeViewItem}">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <Setter Property="Foreground" Value="#FFE8E8E8"/>
                                            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
                                            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
                                            <EventSetter Event="Expanded" Handler="MusicTreeItemExpansionChanged"/>
                                            <EventSetter Event="Collapsed" Handler="MusicTreeItemExpansionChanged"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <Border Margin="0,0,0,2" Padding="{Binding Padding}" Background="{Binding RowBackground}"
                                                    ToolTip="{Binding Tooltip}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{Binding TitleBrush}"
                                                               FontWeight="{Binding FontWeight}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding AssetPath}"
                                                               Foreground="#FF8E9CA4"
                                                               FontSize="10"
                                                               Visibility="{Binding AssetPathVisibility}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                <Border Grid.Row="3" Background="#FF0F1418" BorderBrush="#FF2D3C44" BorderThickness="1" CornerRadius="4" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="Currently Playing" Foreground="#FF9BC7DF" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="txtCurrentMusicTitle"
                                                   AutomationProperties.AutomationId="Main.MusicList.CurrentTitle"
                                                   Text="None"
                                                   Foreground="#FFF2F2F2"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="txtCurrentMusicPath"
                                                   AutomationProperties.AutomationId="Main.MusicList.CurrentPath"
                                                   Text="No active music packet."
                                                   Foreground="#FF89949B"
                                                    FontSize="10"
                                                   Visibility="Collapsed"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="txtCurrentMusicPlaylist"
                                                   AutomationProperties.AutomationId="Main.MusicList.CurrentPlaylist"
                                                   Text="Playlist: Not provided by server"
                                                   Foreground="#FFB4C2C9"
                                                   FontSize="10"
                                                   Margin="0,2,0,6"
                                                   Visibility="Collapsed"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button x:Name="btnStopMusic"
                                                    AutomationProperties.AutomationId="Main.MusicList.Stop"
                                                    Content="Stop"
                                                    Width="82"
                                                    Style="{StaticResource PopupCommandButtonStyle}"
                                                    Click="btnStopMusic_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Thumb Grid.RowSpan="5"
                                       Width="5"
                                       HorizontalAlignment="Right"
                                       Cursor="SizeWE"
                                       Background="Transparent"
                                       Opacity="0"
                                       Margin="0,-10,-10,-10"
                                       DragDelta="MusicListRightResizeThumb_DragDelta"
                                       DragCompleted="PopupResizeThumb_DragCompleted"/>
                                <Thumb Grid.RowSpan="5"
                                       Height="5"
                                       VerticalAlignment="Top"
                                       Cursor="SizeNS"
                                       Background="Transparent"
                                       Opacity="0"
                                       Margin="-10,-10,-10,0"
                                       DragDelta="MusicListTopResizeThumb_DragDelta"
                                       DragCompleted="PopupResizeThumb_DragCompleted"/>
                                <Thumb Grid.RowSpan="5"
                                       Width="14"
                                       Height="14"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Cursor="SizeNESW"
                                       Background="Transparent"
                                       Opacity="0"
                                       Margin="0,-10,-10,0"
                                       DragDelta="MusicListTopRightResizeThumb_DragDelta"
                                       DragCompleted="PopupResizeThumb_DragCompleted"/>
                        </Grid>
                    </Border>
                </Popup>
                <Button x:Name="THEDINGBUTTON" Height="12" Width="12" 
                    BorderBrush="{x:Null}" Foreground="{x:Null}" Padding="0"
                    Canvas.Left="322" Canvas.Top="532"
                    Click="THEDINGBUTTON_Click" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Grid>
                                            <Rectangle x:Name="ButtonImage" Stretch="Fill" Fill="#FF36393F">
                                                <Rectangle.OpacityMask>
                                                    <ImageBrush ImageSource="pack://application:,,,/OceanyaClient;component/Resources/Buttons/Ding.png"/>
                                                </Rectangle.OpacityMask>
                                            </Rectangle>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ButtonImage" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Canvas>
        </Grid>
    </Border>
</local:OceanyaWindowContentControl>
